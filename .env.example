ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-before-production
SESSION_SECRET=change-me-before-production
ADMIN_SESSION_MAX_AGE_SECONDS=86400

# Optional alternative to ADMIN_PASSWORD.
# Value should be a SHA-256 hex digest of the admin password.
ADMIN_PASSWORD_HASH=

# Optional Google OAuth login for authorized admin users.
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=
NUXT_OAUTH_GOOGLE_REDIRECT_URL=
